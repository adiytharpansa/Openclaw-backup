#!/bin/bash
# OpenClaw Quick Launcher - Simple Version
WORKSPACE="/mnt/data/openclaw/workspace/.openclaw/workspace"
PID_FILE="$WORKSPACE/.local/openclaw.pid"
LOG_FILE="$WORKSPACE/.local/logs/openclaw.log"

cd "$WORKSPACE"

case "$1" in
    start)
        echo "🚀 Starting OpenClaw..."
        
        # Check if already running
        if [ -f "$PID_FILE" ]; then
            PID=$(cat "$PID_FILE")
            if ps -p $PID > /dev/null; then
                echo "✅ OpenClaw already running (PID: $PID)"
                exit 0
            fi
        fi
        
        # Create a simple heartbeat process
        echo "Starting OpenClaw heartbeat service..."
        
        # Start background heartbeat
        (
            while true; do
                echo "[$(date '+%Y-%m-%d %H:%M:%S')] OpenClaw heartbeat OK" >> "$LOG_FILE"
                sleep 300
            done
        ) &
        
        HEARTBEAT_PID=$!
        echo $HEARTBEAT_PID > "$PID_FILE"
        
        echo "✅ OpenClaw started!"
        echo "   Heartbeat PID: $HEARTBEAT_PID"
        echo "   Logs: $LOG_FILE"
        ;;
        
    stop)
        echo "🛑 Stopping OpenClaw..."
        if [ -f "$PID_FILE" ]; then
            PID=$(cat "$PID_FILE")
            kill $PID 2>/dev/null || true
            rm "$PID_FILE"
            echo "✅ OpenClaw stopped"
        else
            echo "ℹ OpenClaw not running"
        fi
        ;;
        
    status)
        echo "📊 OpenClaw Status"
        if [ -f "$PID_FILE" ]; then
            PID=$(cat "$PID_FILE")
            if ps -p $PID > /dev/null; then
                echo "✅ RUNNING (PID: $PID)"
            else
                echo "❌ NOT RUNNING"
            fi
        else
            echo "❌ NOT RUNNING"
        fi
        ;;
        
    logs)
        tail -n 50 "$LOG_FILE" 2>/dev/null || echo "No logs yet"
        ;;
        
    *)
        echo "Usage: clawd {start|stop|status|logs}"
        ;;
esac
