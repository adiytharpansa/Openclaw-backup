# Nuclear OpenClaw Configuration Template
# Copy this file to .nuclear.env and fill in YOUR values
# DO NOT commit this file with real secrets to git!

# ==========================================
# Instance Identification
# ==========================================
INSTANCE_ID="nuclear-openclaw-001"

# ==========================================
# Dead Man's Switch Configuration
# ==========================================
# External monitor URL (your server that watches heartbeat)
MONITOR_URL="https://your-monitor-server.com/heartbeat"

# Heartbeat interval (seconds)
HEARTBEAT_INTERVAL=300

# Timeout before deploy triggers (seconds)
HEARTBEAT_TIMEOUT=1800

# ==========================================
# Encryption Keys
# ==========================================
# Generate with: openssl rand -hex 32
STATE_SYNC_KEY="your-32-character-encryption-key-here"
ENCRYPTION_KEY="another-32-character-encryption-key-here"

# ==========================================
# GitHub Configuration
# ==========================================
# Private repo for state backup & GitOps
GITHUB_REPO="https://token@github.com/username/repository.git"

# ==========================================
# VPS Backup Locations
# ==========================================
VPS_HOST="user@1.2.3.4"
VPS_HOST_2="user@5.6.7.8"

# ==========================================
# Alert Channels
# ==========================================
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"

# ==========================================
# Infrastructure Rotation
# ==========================================
ROTATION_INTERVAL=86400  # 24 hours
